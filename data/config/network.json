{
  "id": "network-default",
  "name": "BetaNetworkDefaults",
  "version": "beta-v1",
  "remoteRootName": "NukeAssaltRemotes",
  "folders": {
    "events": "Events",
    "functions": "Functions"
  },
  "events": [
    {
      "name": "MatchStateChanged",
      "channel": "Match",
      "scope": "Broadcast"
    },
    {
      "name": "RoundStateChanged",
      "channel": "Round",
      "scope": "Broadcast"
    },
    {
      "name": "EconomyStateChanged",
      "channel": "Economy",
      "scope": "Targeted"
    },
    {
      "name": "InventoryStateChanged",
      "channel": "Inventory",
      "scope": "Targeted"
    },
    {
      "name": "ObjectiveStateChanged",
      "channel": "Objective",
      "scope": "Broadcast"
    },
    {
      "name": "StatsStateChanged",
      "channel": "Stats",
      "scope": "Targeted"
    },
    {
      "name": "PlayerEliminated",
      "channel": "Combat",
      "scope": "Broadcast"
    },
    {
      "name": "MovementStateChanged",
      "channel": "Movement",
      "scope": "ClientToServer"
    }
  ],
  "functions": [
    {
      "name": "PurchaseRequest",
      "channel": "Shop",
      "scope": "ClientToServer"
    },
    {
      "name": "LoadoutSnapshotRequest",
      "channel": "Inventory",
      "scope": "ClientToServer"
    },
    {
      "name": "ObjectiveActionRequest",
      "channel": "Objective",
      "scope": "ClientToServer"
    },
    {
      "name": "DebugDamageRequest",
      "channel": "Combat",
      "scope": "ClientToServer"
    }
  ]
}
